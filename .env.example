# Copy this file to `.env` and fill in real values for local dev.
# Never commit `.env` to version control.

# ----- Core Django -----
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
# Set to False in production.
DJANGO_DEBUG=True
# Comma-separated. Include your production domain when deploying.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,.localhost

# ----- Site identity -----
SITE_DOMAIN=https://www.brandmeup.org
DEFAULT_FROM_EMAIL=Brand Me Up <contact@brandmeup.org>
SUPPORT_EMAIL=contact@brandmeup.org
SERVER_EMAIL=Brand Me Up <contact@brandmeup.org>

# ----- Email (SMTP transport) -----
# EMAIL_HOST_USER is the Gmail account that authenticates with smtp.gmail.com.
# It stays as the actual Gmail mailbox; the visible From: header is set above
# via DEFAULT_FROM_EMAIL. To make outgoing mail truly display FROM
# contact@brandmeup.org (not Gmail rewriting it), add a "Send mail as" alias
# in that Gmail account's Settings → Accounts.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
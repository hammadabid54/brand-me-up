# Copy this file to `.env` and fill in real values for local dev.
# Never commit `.env` to version control.

# ----- Core Django -----
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
# Set to False in production.
DJANGO_DEBUG=True
# Comma-separated. Include your production domain when deploying.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,.localhost

# ----- Site identity -----
SITE_DOMAIN=https://www.brandmeup.org
DEFAULT_FROM_EMAIL=Brand Me Up <Digitalmomentumx@gmail.com>
SUPPORT_EMAIL=Digitalmomentumx@gmail.com

# ----- Email (SMTP) -----
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=Digitalmomentumx@gmail.com
EMAIL_HOST_PASSWORD=